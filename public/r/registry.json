{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "glasscn",
  "homepage": "https://glasscn.vercel.app/",
  "items": [
    {
      "name": "utils",
      "type": "registry:lib",
      "title": "Utils",
      "dependencies": ["clsx", "tailwind-merge"],
      "files": [
        {
          "path": "lib/utils.ts",
          "type": "registry:lib"
        }
      ]
    },
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "registryDependencies": ["@glasscn/utils"],
      "dependencies": ["@base-ui/react", "class-variance-authority"],
      "files": [
        {
          "path": "components/ui/button.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "glass-button",
      "type": "registry:component",
      "title": "Glass Button",
      "registryDependencies": [
        "@glasscn/utils",
        "@glasscn/button",
        "@glasscn/glass-variants"
      ],
      "description": "Glass Button with 3 different variants to achieve desired frosted view",
      "files": [
        {
          "path": "components/ui/glasscn/glass-button.tsx",
          "type": "registry:component"
        }
      ]
    },
    {
      "name": "card",
      "type": "registry:ui",
      "title": "Card",
      "registryDependencies": ["@glasscn/utils"],
      "files": [
        {
          "path": "components/ui/card.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "glass-card",
      "type": "registry:component",
      "title": "Glass Card",
      "registryDependencies": [
        "@glasscn/utils",
        "@glasscn/card",
        "@glasscn/glass-variants"
      ],
      "description": "Glass Card with 3 different variants to achieve desired frosted view",
      "files": [
        {
          "path": "components/ui/glasscn/glass-card.tsx",
          "type": "registry:component"
        }
      ]
    },
    {
      "name": "glass-variants",
      "type": "registry:lib",
      "title": "Glass Variants",
      "files": [
        {
          "path": "components/ui/glasscn/glass-variants.ts",
          "type": "registry:lib"
        }
      ]
    },
    {
      "name": "alert",
      "type": "registry:ui",
      "title": "Alert",
      "registryDependencies": ["@glasscn/utils"],
      "dependencies": ["class-variance-authority"],
      "files": [
        {
          "path": "components/ui/alert.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "alert-dialog",
      "type": "registry:ui",
      "title": "Alert Dialog",
      "registryDependencies": ["@glasscn/button", "@glasscn/utils"],
      "dependencies": ["@base-ui/react"],
      "files": [
        {
          "path": "components/ui/alert-dialog.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "glass-alert",
      "type": "registry:component",
      "title": "Glass Alert",
      "registryDependencies": [
        "@glasscn/utils",
        "@glasscn/alert",
        "@glasscn/glass-variants"
      ],
      "description": "Glass Alert with 3 different variants to achieve desired frosted view",
      "files": [
        {
          "path": "components/ui/glasscn/glass-alert.tsx",
          "type": "registry:component"
        }
      ]
    },
    {
      "name": "glass-alert-dialog",
      "type": "registry:component",
      "title": "Glass Alert Dialog",
      "registryDependencies": [
        "@glasscn/utils",
        "@glasscn/button",
        "@glasscn/glass-button",
        "@glasscn/alert-dialog",
        "@glasscn/glass-variants"
      ],
      "description": "Glass Alert Dialog with 3 different variants to achieve desired frosted view",
      "files": [
        {
          "path": "components/ui/glasscn/glass-alert-dialog.tsx",
          "type": "registry:component"
        }
      ]
    }
  ]
}
